{
  "name": "agent-pocket",
  "version": "0.1.0",
  "description": "Daemon that bridges Claude Code sessions on your Mac to the Agent Pocket iOS app — remote control, permission approvals, and session monitoring with end-to-end encryption.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "agent-pocket": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "node --import tsx --test test/*.test.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agent",
    "daemon",
    "remote-control",
    "ios",
    "websocket"
  ],
  "author": "Jiayin Pei",
  "license": "MIT",
  "homepage": "https://github.com/928PJY/agent-pocket-daemon#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/928PJY/agent-pocket-daemon.git"
  },
  "bugs": {
    "url": "https://github.com/928PJY/agent-pocket-daemon/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.98",
    "agent-pocket-protocol": "^0.2.0",
    "bonjour-service": "^1.3.0",
    "chalk": "^5.3.0",
    "jsonwebtoken": "^9.0.2",
    "qrcode-terminal": "^0.12.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
